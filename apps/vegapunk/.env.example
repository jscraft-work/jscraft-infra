GHCR_OWNER=jscraft-work

# LLM 래퍼 (호스트 launchd, openclaw/nanobot)
LLM_BASE_URL=http://host.docker.internal:18000
LLM_LEVEL=low

# 데이터/모델 경로 (컨테이너 내부, 볼륨 마운트됨)
VEGAPUNK_DB=/app/data/vegapunk.db
HF_HOME=/app/models

# bj-auth OAuth2 (authorization-code + PKCE 공개 클라이언트)
AUTH_ENABLED=1
AUTH_BASE_URL=https://auth.jscraft.work
# 서버-투-서버(token/userinfo) 내부 호출 — 컨테이너에서 bj-auth 컨테이너 직접. 미설정 시 AUTH_BASE_URL.
AUTH_INTERNAL_URL=http://bj-auth:9000
OAUTH_CLIENT_ID=vegapunk-web
OAUTH_REDIRECT_URI=https://vegapunk.jscraft.work/auth/callback
OAUTH_SCOPE=openid profile
ALLOWED_EMAILS=ocpek@kakao.com

# 서버세션 (Redis 백엔드 — jscraft 네트워크의 redis 컨테이너)
REDIS_URL=redis://redis:6379
COOKIE_SECURE=1
