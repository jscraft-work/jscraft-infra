GHCR_OWNER=jscraft-work

# Database — jscraft 네트워크 내부 호스트명
DB_URL=jdbc:postgresql://postgres:5432/alt
DB_USERNAME=bj_auth_user
DB_PASSWORD=change_me

# Redis — jscraft 네트워크 내부 호스트명
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Auth (32자 이상)
AUTH_JWT_SECRET=change-this-jwt-secret-change-this-jwt-secret

# KIS
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_HTS_ID=
KIS_ACCT_STOCK=
KIS_PROD_TYPE=01
KIS_ENVIRONMENT=real
KIS_WS_ENABLED=false

# DART
DART_API_KEY=

# Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM — 호스트(맥미니)에서 launchd로 도는 HTTP wrapper(POST /ask)를 컨테이너에서 호출.
# wrapper가 openclaw(level=normal) / nanobot(level=high) subprocess를 대신 실행한다.
LLM_HTTP_BASE_URL=http://host.docker.internal:18000
LLM_OPENCLAW_TIMEOUT_SECONDS=60
LLM_NANOBOT_TIMEOUT_SECONDS=120
